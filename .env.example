DATABASE_URL="postgresql://user:password@localhost:5432/vibeuidb?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3000

# Storage Configuration (Cloudflare R2 or AWS S3)
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com" # Or AWS S3 endpoint
S3_REGION="auto" # e.g., 'auto' for Cloudflare R2, 'us-east-1' for AWS
S3_ACCESS_KEY_ID="your_access_key_id"
S3_SECRET_ACCESS_KEY="your_secret_access_key"
S3_PUBLIC_URL="https://pub-xxxxxxxxxxxxxx.r2.dev" # Publicly accessible URL for your bucket
S3_BUCKET_NAME="your_bucket_name"
